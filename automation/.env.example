# ============================================
# 股小智 · n8n 自动化环境变量模板
# 复制为 .env 后填入真实值
# ============================================

# --- n8n 基础配置 ---
N8N_USER=admin
N8N_PASSWORD=your_secure_password
N8N_HOST=localhost
WEBHOOK_URL=http://localhost:5678

# --- 股小智项目API ---
# 本地开发用 http://host.docker.internal:5000
# 生产环境用 https://stock-ai-6plg.onrender.com
STOCK_API_URL=http://host.docker.internal:5000

# --- 小红书发布API ---
# 需接入第三方服务（如 小红书开放平台 / 第三方SaaS）
XIAOHONGSHU_API_URL=https://api.example.com/xiaohongshu/publish

# --- 微信/飞书机器人Webhook ---
# 企业微信： https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx
# 飞书： https://open.feishu.cn/open-apis/bot/v2/hook/xxx
WECHAT_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your_key

# --- 邮件告警配置 ---
ALERT_EMAIL_FROM=alert@guxiaozhi.com
ALERT_EMAIL_TO=your-email@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# --- Codex AI 修复 ---
CODEX_API_URL=https://api.openai.com
CODEX_API_KEY=sk-your-codex-key

# --- GitHub 自动PR ---
GITHUB_OWNER=your-github-username
GITHUB_REPO=stock-ai
GITHUB_TOKEN=ghp_your_github_token

# --- Slack/飞书通知频道 ---
SLACK_CHANNEL=#guxiaozhi-alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx

# --- 监控的工作流ID（逗号分隔） ---
STOCK_WORKFLOW_IDS=daily-briefing,stock-alert,dashboard-update